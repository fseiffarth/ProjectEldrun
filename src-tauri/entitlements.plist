<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- WKWebView / JavaScriptCore need JIT and writable executable memory. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Eldrun spawns child processes (PTYs, git, ssh, sshfs, tex, ollama) and
       may load third-party dylibs (e.g. macFUSE); relax library validation. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Eldrun augments the PATH/env of child processes it launches. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!-- Network access: SSH, localhost Ollama, the dev server during tauri dev. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
  <!-- AppleScript (osascript) for privileged helpers / future workspace hooks. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
